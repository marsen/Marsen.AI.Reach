#!/bin/bash

# Resolve symlinks to find package directory
SOURCE="$0"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
PACKAGE_DIR="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"

CONFIG_DIR="$HOME/.rai"
ENV_FILE="$CONFIG_DIR/.env"
TMUX_SESSION="claude-reach"
CLIENT="$PACKAGE_DIR/bin/client.mjs"
LAUNCHD_LABEL="com.marsen.rai"
PLIST_PATH="$HOME/Library/LaunchAgents/${LAUNCHD_LABEL}.plist"

# 解析子命令與旗標
SUBCOMMAND=""
WORK_DIR=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    init|start|stop|status) SUBCOMMAND="$1"; shift ;;
    -p|--path) WORK_DIR="$2"; shift 2 ;;
    *) WORK_DIR="$1"; shift ;;
  esac
done
WORK_DIR="${WORK_DIR:-$(pwd)}"

# 處理子命令
if [ "$SUBCOMMAND" = "init" ]; then
  exec node "$PACKAGE_DIR/bin/init.mjs"
fi

if [ "$SUBCOMMAND" = "stop" ]; then
  echo "🛑 停止服務..."
  launchctl unload "$PLIST_PATH" 2>/dev/null && echo "✅ 服務已停止" || echo "❌ 停止失敗（服務可能未安裝）"
  exit 0
fi

if [ "$SUBCOMMAND" = "status" ]; then
  INFO=$(node "$CLIENT" info 2>/dev/null)
  if [ $? -ne 0 ]; then
    echo "💤 Bot 未運行"
  else
    SESSION=$(echo "$INFO" | node -e "process.stdin.resume();let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const o=JSON.parse(d);console.log(o.session)})")
    WORK=$(echo "$INFO" | node -e "process.stdin.resume();let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const o=JSON.parse(d);console.log(o.workDir)})")
    echo "✅ Bot 運行中"
    echo "   Claude session：${SESSION}"
    echo "   目前目錄：${WORK}"
  fi
  exit 0
fi

# 已經在 claude-reach session 裡
if [ -n "$TMUX" ]; then
  CURRENT_SESSION="$(tmux display-message -p '#S' 2>/dev/null)"
  if [ "$CURRENT_SESSION" = "$TMUX_SESSION" ]; then
    echo "✅ 你已經在 $TMUX_SESSION session 中了"
    exit 0
  fi
fi

# Check config
if [ ! -f "$ENV_FILE" ]; then
  echo "❌ 尚未設定，請先執行："
  echo "   rai init"
  exit 1
fi

# Check launchd service installed
if [ ! -f "$PLIST_PATH" ]; then
  echo "❌ 尚未安裝服務，請先執行："
  echo "   rai init"
  exit 1
fi

# Check if bot is running via socket
BOT_STATUS=$(node "$CLIENT" status 2>/dev/null)
BOT_RUNNING=$?

if [ $BOT_RUNNING -ne 0 ]; then
  echo "⏳ Bot 未回應，嘗試啟動服務..."
  launchctl load "$PLIST_PATH" 2>/dev/null || launchctl start "$LAUNCHD_LABEL" 2>/dev/null
fi

if [ $BOT_RUNNING -eq 0 ]; then
  INFO=$(node "$CLIENT" info 2>/dev/null)
  CURRENT_WORK=$(echo "$INFO" | node -e "process.stdin.resume();let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{try{const o=JSON.parse(d);console.log(o.workDir)}catch{}})" 2>/dev/null)

  if [ "$BOT_STATUS" = "active" ]; then
    SESSION_STATUS="進行中"
    HAS_SESSION=true
  else
    SESSION_STATUS="無"
    HAS_SESSION=false
  fi

  echo "⚠️  Bot 已在執行中"
  echo "    Claude session：$SESSION_STATUS"
  echo "    目前目錄：${CURRENT_WORK:-(空)}"
  [ "$CURRENT_WORK" != "$WORK_DIR" ] && echo "    新目錄：  $WORK_DIR"
  echo ""
  if command -v gum >/dev/null 2>&1; then
    if [ "$HAS_SESSION" = "true" ]; then
      selected=$(gum choose "進入現有 session ($CURRENT_WORK)" "切換到新目錄重啟 ($WORK_DIR)" "取消")
      case "$selected" in
        "進入現有"*) choice=1 ;;
        "切換到"*) choice=2 ;;
        *) choice=3 ;;
      esac
    else
      selected=$(gum choose "啟動新 session" "取消")
      case "$selected" in
        "啟動"*) choice=1 ;;
        *) choice=3 ;;
      esac
    fi
  else
    if [ "$HAS_SESSION" = "true" ]; then
      echo "  [1] 進入現有 session ($CURRENT_WORK)"
      echo "  [2] 切換到新目錄重啟 ($WORK_DIR)"
      echo "  [3] 取消"
      echo ""
      printf "請選擇 [1-3]: "
      read choice
    else
      echo "  [1] 啟動新 session"
      echo "  [2] 取消"
      echo ""
      printf "請選擇 [1-2]: "
      read choice
      [ "$choice" = "2" ] && choice="3"
    fi
  fi

  case "$choice" in
    1)
      if [ "$HAS_SESSION" = "false" ]; then
        echo "⏳ 等待 Claude session 就緒..."
        RESULT=$(node "$CLIENT" start "$WORK_DIR" 2>/dev/null)
        if [ $? -ne 0 ]; then
          echo "❌ 無法啟動 session"
          exit 1
        fi
        echo "✅ $RESULT"
      fi
      if [ -n "$TMUX" ]; then
        tmux switch-client -t "$TMUX_SESSION"
        exit 0
      else
        exec tmux attach -t "$TMUX_SESSION"
      fi
      ;;
    2)
      tmux kill-session -t "$TMUX_SESSION" 2>/dev/null
      launchctl stop "$LAUNCHD_LABEL" 2>/dev/null
      sleep 2
      launchctl start "$LAUNCHD_LABEL" 2>/dev/null
      ;;
    3)
      exit 0
      ;;
    *)
      echo "無效選項"
      exit 1
      ;;
  esac
fi

echo "🚀 Bot 啟動中..."
echo "⏳ 等待 Claude session 就緒..."
for i in $(seq 1 60); do
  RESULT=$(node "$CLIENT" start "$WORK_DIR" 2>/dev/null)
  if [ $? -eq 0 ]; then
    echo "✅ 連接中..."
    if [ -n "$TMUX" ]; then
      tmux switch-client -t "$TMUX_SESSION"
      exit 0
    else
      exec tmux attach -t "$TMUX_SESSION"
    fi
  fi
  sleep 1
done

echo "❌ Timeout：Claude session 未就緒"
exit 1
