# 防止直接 commit 到 main 或 master 分支
branch=$(git symbolic-ref --short HEAD 2>/dev/null)
if [ "$branch" = "main" ] || [ "$branch" = "master" ]; then
  # 白名單：這些檔案允許直接 commit 到 main
  ALLOWED_FILES="CLAUDE.md README.md"

  staged=$(git diff --cached --name-only)
  all_allowed=true
  for f in $staged; do
    if ! echo "$ALLOWED_FILES" | grep -qw "$f"; then
      all_allowed=false
      break
    fi
  done

  if [ "$all_allowed" = false ]; then
    echo "❌ 禁止直接 commit 到 $branch 分支！"
    echo "   請先建立 feature branch："
    echo "   git checkout -b <branch-name>"
    exit 1
  fi
fi

npm test
